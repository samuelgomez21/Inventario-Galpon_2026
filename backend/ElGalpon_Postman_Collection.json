{
	"info": {
		"_postman_id": "el-galpon-api-collection",
		"name": "El Galpón - API Backend",
		"description": "Colección completa de endpoints para el sistema de gestión de inventario El Galpón",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000/api",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "🔐 Autenticación",
			"item": [
				{
					"name": "1. Solicitar Código de Verificación",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"manuela.gomez@elgalpon-alcala.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/solicitar-codigo",
							"host": ["{{base_url}}"],
							"path": ["auth", "solicitar-codigo"]
						},
						"description": "Envía un código de 6 dígitos al email del usuario registrado. El código expira en 10 minutos."
					}
				},
				{
					"name": "2. Verificar Código (Login)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token guardado automáticamente');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"manuela.gomez@elgalpon-alcala.com\",\n    \"codigo\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/verificar-codigo",
							"host": ["{{base_url}}"],
							"path": ["auth", "verificar-codigo"]
						},
						"description": "Verifica el código recibido por email y devuelve un token de autenticación. El token se guarda automáticamente en la variable de colección."
					}
				},
				{
					"name": "3. Obtener Usuario Actual",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/me",
							"host": ["{{base_url}}"],
							"path": ["auth", "me"]
						},
						"description": "Obtiene la información del usuario autenticado actualmente."
					}
				},
				{
					"name": "4. Cerrar Sesión",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/logout",
							"host": ["{{base_url}}"],
							"path": ["auth", "logout"]
						},
						"description": "Cierra la sesión actual (revoca el token actual)."
					}
				},
				{
					"name": "5. Cerrar Todas las Sesiones",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/logout-all",
							"host": ["{{base_url}}"],
							"path": ["auth", "logout-all"]
						},
						"description": "Cierra todas las sesiones del usuario (revoca todos los tokens)."
					}
				}
			]
		},
